{
  "version": 2,
  "builds": [
    {
      "src": "bm_activity_logger.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/entries.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/members.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/members",
      "dest": "/api/members.js"
    },
    {
      "src": "/api/entries",
      "dest": "/api/entries.js"
    },
    {
      "src": "/",
      "dest": "/bm_activity_logger.html"
    },
    {
      "src": "/bm_activity_logger.html",
      "dest": "/bm_activity_logger.html"
    }
  ]
}
